# Port to expose Overleaf on
OVERLEAF_PORT=8080

# Application name shown in the UI
OVERLEAF_APP_NAME=Overleaf

# Admin email (used for the first admin account)
ADMIN_EMAIL=you@example.com

# Data directories
OVERLEAF_DATA_LOCATION=./data/overleaf
MONGO_DATA_LOCATION=./data/mongo

# Nginx / Certbot
DOMAIN=latex.example.com
CERTBOT_EMAIL=you@example.com

# SMTP (for invitations, password resets, notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_ADDRESS=you@gmail.com
