# Port to expose Overleaf on
OVERLEAF_PORT=8080

# Application name shown in the UI
OVERLEAF_APP_NAME=Overleaf

# Admin email (used for the first admin account)
ADMIN_EMAIL=you@example.com

# Data directories
OVERLEAF_DATA_LOCATION=./data/overleaf
MONGO_DATA_LOCATION=./data/mongo

# Nginx / Certbot
DOMAIN=latex.example.com
CERTBOT_EMAIL=you@example.com
