# Immich Version - pin to a specific version or use 'release' for latest stable
IMMICH_VERSION=release

# Port to expose Immich on
IMMICH_PORT=2283

# Directory where uploaded photos/videos will be stored
UPLOAD_LOCATION=./data/upload

# Database credentials
DB_PASSWORD=changeme
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# Directory for database storage
DB_DATA_LOCATION=./data/postgres

# Nginx / Certbot
DOMAIN=photos.example.com
CERTBOT_EMAIL=you@example.com
