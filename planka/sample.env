# Planka web interface port
PLANKA_PORT=3000

# Public URL. Use http://<server-ip>:3000 for local-only access or https://tasks.example.com behind nginx.
BASE_URL=https://tasks.example.com

# Secret key (generate with: openssl rand -hex 64)
SECRET_KEY=changeme

# Set true when running behind nginx or another reverse proxy
TRUST_PROXY=true

# Default application language
DEFAULT_LANGUAGE=en-US

# Block internal hosts from Planka outgoing requests
OUTGOING_BLOCKED_HOSTS=localhost,postgres

# Nginx / Certbot
DOMAIN=tasks.example.com
CERTBOT_EMAIL=you@example.com
