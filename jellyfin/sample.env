# Jellyfin web interface port
JELLYFIN_PORT=8096

# Timezone
TZ=Asia/Seoul

# Host paths for persistent data (point JELLYFIN_MEDIA at /mnt/external for big libraries)
JELLYFIN_CONFIG=./data/config
JELLYFIN_CACHE=./data/cache
JELLYFIN_MEDIA=./data/media

# Nginx / Certbot
DOMAIN=jellyfin.example.com
CERTBOT_EMAIL=you@example.com
