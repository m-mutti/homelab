# Host port to expose the Dawarich web UI on
DAWARICH_PORT=3000

# Timezone
TIME_ZONE=Asia/Seoul

# Database credentials (used by both dawarich_db and the app/sidekiq)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=dawarich_production

# Rails secret. Generate one with: openssl rand -hex 64
# Avoid $, !, ^ characters (Docker Compose treats them specially).
SECRET_KEY_BASE=CHANGE_ME

# Hosts allowed to reach the app. Add your domain when using nginx.
# e.g. dawarich.example.com,localhost,::1,127.0.0.1
APPLICATION_HOSTS=localhost,::1,127.0.0.1

# Protocol the app builds URLs with. Set to "https" when behind nginx + SSL.
APPLICATION_PROTOCOL=http

# Nginx / Certbot
DOMAIN=dawarich.example.com
CERTBOT_EMAIL=you@example.com
