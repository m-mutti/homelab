# AriaNg web interface port
ARIANG_PORT=6880

# Aria2 RPC port. Bound to 127.0.0.1 only; nginx proxies /jsonrpc to it.
ARIA2_RPC_PORT=6800

# Aria2 BitTorrent / DHT listen port. Open this TCP/UDP port on the firewall if using torrents.
ARIA2_LISTEN_PORT=6888

# User and group IDs for downloaded files
PUID=1000
PGID=1000
UMASK_SET=022

# RPC secret used by AriaNg to control Aria2 (generate with: openssl rand -hex 32)
RPC_SECRET=changeme

# Timezone
TZ=Asia/Seoul

# Aria2 tuning
DISK_CACHE=64M
IPV6_MODE=false
UPDATE_TRACKERS=true

# Data directories
ARIA2_CONFIG_LOCATION=./data/aria2-config
DOWNLOADS_LOCATION=/mnt/external/downloads

# Nginx / Certbot
DOMAIN=downloads.example.com
CERTBOT_EMAIL=you@example.com
