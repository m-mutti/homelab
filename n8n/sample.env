# n8n web interface port
N8N_PORT=5678

# Timezone
TZ=Asia/Seoul

# Public domain for n8n
DOMAIN=n8n.example.com

# Keep true when serving n8n over HTTPS
N8N_SECURE_COOKIE=true

# Recommended by n8n for newer versions
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_RUNNERS_ENABLED=true

# Encryption key for credentials (generate with: openssl rand -hex 32)
# Keep this value stable forever; changing it breaks stored credentials.
N8N_ENCRYPTION_KEY=changeme

# PostgreSQL
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=changeme

# Nginx / Certbot
CERTBOT_EMAIL=you@example.com
