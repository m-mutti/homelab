# Primary mail server hostname. This must be a real DNS name, not just the bare domain.
MAILCOW_HOSTNAME=mail.example.com

# Main domain you will receive mail for.
MAIL_DOMAIN=example.com

# Timezone
MAILCOW_TZ=Asia/Seoul

# Official mailcow branch to install/update from
MAILCOW_BRANCH=master

# Local checkout created by bootstrap-mailcow.sh
MAILCOW_DIR=./mailcow-dockerized

# Web UI ports used behind this server's host nginx
MAILCOW_HTTP_BIND=127.0.0.1
MAILCOW_HTTP_PORT=8088
MAILCOW_HTTPS_BIND=127.0.0.1
MAILCOW_HTTPS_PORT=8443

# Let host nginx/certbot manage HTTPS, then copy certs into mailcow for SMTP/IMAP TLS
SKIP_LETS_ENCRYPT=y

# Set y only if your server has working public IPv6 and matching AAAA/PTR DNS
IPV6_BOOL=n

# Docker subnet for mailcow's private network.
# Change this if Docker reports "Pool overlaps with other one on this address space".
MAILCOW_IPV4_NETWORK=172.31.1.0/24

# ClamAV is useful but memory-heavy. Set n if the server has enough RAM.
SKIP_CLAMD=y

# Nginx / Certbot
CERTBOT_EMAIL=you@example.com
